      "dev": {
        "continuous": true,
        "command": "vite",
        "options": {
          "cwd": "frontend"
        },
        "metadata": {
          "technologies": [
            "vite"
          ],
          "description": "Starts Vite dev server",
          "help": {
            "command": "yarn vite --help",
            "example": {
              "options": {
