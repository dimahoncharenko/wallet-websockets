            "typescript"
          ],
          "help": {
            "command": "yarn tsc -p tsconfig.app.json --help",
            "example": {
              "options": {
                "noEmit": true
              }
            }
          }
        }
      },
      "build-deps": {
        "dependsOn": [
          "^build"
        ]
      },
      "watch-deps": {
        "continuous": true,
        "dependsOn": [
          "build-deps"
        ],
        "command": "yarn nx watch --projects frontend --includeDependentProjects -- yarn nx build-deps frontend"
      }
    },
